# =================================================================
# AIアプリ開発ナレッジ共有ハブ — 環境変数テンプレート
#
# 注意：VITE_* で始まる変数は ビルド成果物の JS に埋め込まれます。
#       秘密値（API key の制限対象、シークレット鍵）を絶対に書かないでください。
# =================================================================

# ----- Vite SPA 用（ブラウザに露出する） -----
VITE_USE_EMULATOR=1
VITE_FIREBASE_API_KEY=demo-key
VITE_FIREBASE_AUTH_DOMAIN=aidev-knowledge-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=aidev-knowledge-dev
VITE_FIREBASE_STORAGE_BUCKET=aidev-knowledge-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Emulator 接続先（ブラウザから見える host:port、+200 シフト済）
VITE_FIREBASE_AUTH_EMULATOR_HOST=localhost:9299
VITE_FIRESTORE_EMULATOR_HOST=localhost:8280

# Storage Provider 切替
# minio  → og-proxy 経由で MinIO（PoC）
# firebase → 直接 Firebase Storage（本番）
VITE_STORAGE_PROVIDER=minio

# og-proxy エンドポイント（OG/サムネ取得 + MinIO署名URL発行、+200 シフト済）
VITE_OG_PROXY_URL=http://localhost:8987

# ----- og-proxy / minio-init 用（サーバ側のみ、ブラウザに露出しない） -----
# 初回セットアップ時に `openssl rand -hex 16` で生成した値に必ず変更
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEME_minioadmin_dev_only
MINIO_BUCKET=aidev-uploads
MINIO_ENDPOINT=http://minio:9000

# og-proxy が Firebase Auth Emulator を呼び出すための project ID
FIREBASE_PROJECT_ID=aidev-knowledge-dev
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099

# pnpm test:rules（Node から Emulator に接続する Rules テスト用）
FIRESTORE_EMULATOR_HOST=firebase-emulator:8080

# ----- 本番Blaze 移行時に追加する変数（PoC では未使用） -----
# FIREBASE_SERVICE_ACCOUNT_PATH=/secrets/firebase-admin.json
# RECAPTCHA_SITE_KEY=...
# APP_CHECK_DEBUG_TOKEN=...
