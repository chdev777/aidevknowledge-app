rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // 共通ヘルパ
    // ========================================
    function signedIn() {
      return request.auth != null;
    }

    /**
     * メール検証済か。Firebase Auth のリンクをクリックしたユーザのみ true。
     * 投稿・編集・削除など書込系の主要パスはここを必須にする。
     * 例外: bootstrap 経路（users/handles/private の create）と読取系は signedIn() のまま。
     */
    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function ownerOf(d) {
      return signedIn() && request.auth.uid == d.createdBy;
    }

    function shared(d) {
      return d.visibility == 'shared';
    }

    function visibleTo(d) {
      return shared(d) || ownerOf(d);
    }

    /** 投稿系コレクション共通の create バリデーション（要メール検証） */
    function commonCreate(d) {
      return verified()
        && d.createdBy == request.auth.uid
        && d.createdAt == request.time
        && d.visibility in ['private', 'shared']
        && d.tags is list
        && d.tags.size() <= 10;
    }

    /** update 時に変更不可なフィールド（所有権・タイムスタンプ） */
    function immutableOnUpdate(prev, next) {
      return next.createdBy == prev.createdBy
        && next.createdAt == prev.createdAt;
    }

    function isString(d, field, max) {
      return d[field] is string && d[field].size() > 0 && d[field].size() <= max;
    }

    /**
     * 呼出元が管理者ロールかどうか（users/{uid}.role を get で確認）
     * 検証済 + role='管理者' を満たす場合のみ true。未検証管理者は admin 権限を持てない。
     */
    function isAdmin() {
      return verified()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == '管理者';
    }

    // ========================================
    // users — public profile
    // ========================================
    match /users/{uid} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == uid
        // 自己申告できる role は限定（管理者は招待のみ）
        && request.resource.data.role in ['DX推進', '情報支援']
        && request.resource.data.handle is string
        && request.resource.data.handle.size() >= 3
        && request.resource.data.handle.size() <= 32
        && request.resource.data.handle.matches('^[a-zA-Z0-9_.-]+$');

      // 本人による update（role/handle は不変、要メール検証）
      // または 管理者による他者の role 変更（handle・他フィールドは触れない、isAdmin は verified 必須）
      allow update: if verified() && (
        (
          request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.handle == resource.data.handle
        ) || (
          isAdmin()
          && request.auth.uid != uid
          && request.resource.data.handle == resource.data.handle
          && request.resource.data.role in ['DX推進', '情報支援', '管理者']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['role', 'updatedAt'])
        )
      );

      allow delete: if false;

      // 個人情報サブドキュメント
      match /private/{docId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    // ========================================
    // handles — ユニーク制約用ロックドキュメント
    // ========================================
    match /handles/{handle} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && handle.matches('^[a-zA-Z0-9_.-]+$')
        && handle.size() >= 3
        && handle.size() <= 32;
      allow update, delete: if false;
    }

    // ========================================
    // links / notes / apps — 投稿系（同パターン）
    // ========================================
    match /links/{id} {
      allow read: if signedIn() && visibleTo(resource.data);
      allow create: if commonCreate(request.resource.data)
        && isString(request.resource.data, 'title', 200)
        && isString(request.resource.data, 'url', 2000)
        && request.resource.data.url.matches('^https?://.+')
        && request.resource.data.userComment is string
        && request.resource.data.userComment.size() <= 2000
        && request.resource.data.summary is string
        && request.resource.data.summary.size() <= 2000;
      allow update: if verified() && ownerOf(resource.data)
        && immutableOnUpdate(resource.data, request.resource.data)
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 10;
      allow delete: if verified() && (ownerOf(resource.data) || isAdmin());
    }

    match /notes/{id} {
      allow read: if signedIn() && visibleTo(resource.data);
      allow create: if commonCreate(request.resource.data)
        && isString(request.resource.data, 'title', 200)
        && request.resource.data.purpose is string
        && request.resource.data.purpose.size() <= 4000
        && request.resource.data.tried is string
        && request.resource.data.tried.size() <= 8000
        && request.resource.data.result is string
        && request.resource.data.result.size() <= 4000
        && request.resource.data.conclusion is string
        && request.resource.data.conclusion.size() <= 2000;
      allow update: if verified() && ownerOf(resource.data)
        && immutableOnUpdate(resource.data, request.resource.data);
      allow delete: if verified() && (ownerOf(resource.data) || isAdmin());
    }

    match /apps/{id} {
      allow read: if signedIn() && visibleTo(resource.data);
      allow create: if commonCreate(request.resource.data)
        && isString(request.resource.data, 'name', 200)
        && isString(request.resource.data, 'url', 2000)
        && request.resource.data.url.matches('^https?://.+')
        && request.resource.data.summary is string
        && request.resource.data.summary.size() <= 4000
        && request.resource.data.purpose is string
        && request.resource.data.purpose.size() <= 4000
        && request.resource.data.caution is string
        && request.resource.data.caution.size() <= 2000
        && request.resource.data.stats.views == 0
        && request.resource.data.stats.comments == 0
        && request.resource.data.stats.likes == 0;
      allow update: if verified() && ownerOf(resource.data)
        && immutableOnUpdate(resource.data, request.resource.data);
      allow delete: if verified() && (ownerOf(resource.data) || isAdmin());
    }

    // ========================================
    // questions — 採用回答 / 投票
    // ========================================
    match /questions/{id} {
      allow read: if signedIn() && visibleTo(resource.data);
      allow create: if commonCreate(request.resource.data)
        && isString(request.resource.data, 'title', 200)
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 8000
        && request.resource.data.answerCount == 0
        && !('acceptedAnswerId' in request.resource.data);
      // 質問本人だけが本文編集可能（要メール検証）
      allow update: if verified() && ownerOf(resource.data)
        && immutableOnUpdate(resource.data, request.resource.data);
      allow delete: if verified() && (ownerOf(resource.data) || isAdmin());

      // 回答（サブコレクション）
      match /answers/{aid} {
        function parentQuestion() {
          return get(/databases/$(database)/documents/questions/$(id)).data;
        }
        function isQuestionOwner() {
          return verified() && request.auth.uid == parentQuestion().createdBy;
        }

        allow read: if signedIn() && visibleTo(parentQuestion());

        allow create: if verified()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.createdAt == request.time
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 8000
          && request.resource.data.votes == 0
          && request.resource.data.accepted == false;

        // update は3パターン：投稿者本文編集 / 質問者の採用変更 / 投票 ±1（全て要検証）
        allow update: if (
          verified() && ownerOf(resource.data)
          && immutableOnUpdate(resource.data, request.resource.data)
          && request.resource.data.votes == resource.data.votes
          && request.resource.data.accepted == resource.data.accepted
        ) || (
          isQuestionOwner()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['accepted', 'updatedAt'])
        ) || (
          verified()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['votes', 'updatedAt'])
          && (
            request.resource.data.votes == resource.data.votes + 1
            || request.resource.data.votes == resource.data.votes - 1
          )
        );

        allow delete: if verified() && (ownerOf(resource.data) || isAdmin());
      }
    }

    // ========================================
    // comments — 親doc visibility を非正規化保持
    // ========================================
    match /comments/{id} {
      allow read: if signedIn()
        && (resource.data.targetVisibility == 'shared' || ownerOf(resource.data));

      allow create: if verified()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.targetVisibility in ['private', 'shared']
        && request.resource.data.targetType in ['link', 'question', 'note', 'app']
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() > 0
        && request.resource.data.type in [
            '感想',
            '改善提案',
            '不具合報告',
            '活用アイデア',
            '技術メモ',
            'セキュリティ指摘'
          ]
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000;

      allow update: if verified() && ownerOf(resource.data)
        && immutableOnUpdate(resource.data, request.resource.data)
        && request.resource.data.targetType == resource.data.targetType
        && request.resource.data.targetId == resource.data.targetId;

      allow delete: if verified() && (ownerOf(resource.data) || isAdmin());
    }

    // ========================================
    // tags — マスタ。read 全認証ユーザー / write 管理者のみ
    // ========================================
    match /tags/{id} {
      allow read: if signedIn();

      allow create: if isAdmin()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 32
        && request.resource.data.type in [
          '技術', 'ツール', '開発', '用途', 'セキュリティ', '状態'
        ];

      allow update: if isAdmin()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 32
        && request.resource.data.type in [
          '技術', 'ツール', '開発', '用途', 'セキュリティ', '状態'
        ];

      allow delete: if isAdmin();
    }

    match /projects/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    // ========================================
    // admin_logs — 監査ログ（管理者のみ read/create、不変）
    // ========================================
    match /admin_logs/{id} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.action in [
          'set_role',
          'delete_link', 'delete_qa', 'delete_note', 'delete_app',
          'create_tag', 'update_tag', 'delete_tag',
          'set_feedback_status'
        ]
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    // ========================================
    // favorites — 本人のみ。read は signedIn()、write は要メール検証
    // ========================================
    match /favorites/{uid}/items/{id} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if verified() && request.auth.uid == uid;
    }

    // ========================================
    // feedbacks — ユーザー → 運営の片方向投稿
    // read/update は管理者のみ。create は本人、status は 'new' で固定。
    // status 遷移は双方向自由（new ↔ acknowledged ↔ resolved）。
    // 状態変更はすべて admin_logs に記録されるため逆遷移も監査可能。
    // delete は禁止（履歴保持）。
    // ========================================
    match /feedbacks/{id} {
      allow read: if isAdmin();

      allow create: if verified()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.category in ['bug', 'feature', 'other']
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000
        // 表示用スナップショット: 改ざん耐性は限定的だが size 上限と string 型は強制
        && request.resource.data.userHandleSnap is string
        && request.resource.data.userHandleSnap.size() <= 32
        && request.resource.data.userNameSnap is string
        && request.resource.data.userNameSnap.size() <= 64
        // 送信元ビューパス（例: '/links'）。256 字あれば十分
        && request.resource.data.currentView is string
        && request.resource.data.currentView.size() <= 256
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // 管理者のみ、status と updatedAt のみ更新可。
      // 任意の遷移を許容（逆遷移含む）。状態変更はすべて admin_logs に記録される。
      allow update: if isAdmin()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.message == resource.data.message
        && request.resource.data.category == resource.data.category
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['new', 'acknowledged', 'resolved'];

      allow delete: if false;
    }
  }
}
