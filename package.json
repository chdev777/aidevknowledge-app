{
  "name": "aidev-knowledge-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "build:prod": "tsc --noEmit && tools/scripts/build-prod.sh",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run src/test/unit",
    "test:rules": "vitest run src/test/rules --no-file-parallelism",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "seed": "FIRESTORE_EMULATOR_HOST=firebase-emulator:8080 FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099 GCLOUD_PROJECT=aidev-knowledge-dev tsx tools/scripts/seed.ts",
    "env-guard": "tsx tools/scripts/env-guard.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "firebase": "^10.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "rehype-sanitize": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "firebase-admin": "^12.6.0",
    "googleapis": "^171.4.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0"
}
